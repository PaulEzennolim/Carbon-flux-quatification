# ============================================
# Carbon Flux Quantification - Git Attributes
# ============================================

# ============================================
# AUTO DETECT
# ============================================
* text=auto

# ============================================
# SOURCE CODE
# ============================================
*.py text eol=lf diff=python
*.ipynb text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# ============================================
# DOCUMENTATION
# ============================================
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Thesis LaTeX files
*.tex text eol=lf diff=tex
*.bib text eol=lf
*.cls text eol=lf
*.sty text eol=lf

# ============================================
# CONFIG FILES
# ============================================
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# ============================================
# DATA FILES (Mark as binary - don't diff)
# ============================================
*.csv binary
*.tsv binary
*.xlsx binary
*.xls binary
*.npy binary
*.npz binary
*.pkl binary
*.pickle binary
*.h5 binary
*.hdf5 binary
*.nc binary
*.mat binary

# ============================================
# MODEL FILES (Mark as binary)
# ============================================
*.pth binary
*.pt binary
*.ckpt binary
*.pb binary
*.h5 binary
*.weights binary
*.model binary

# ============================================
# IMAGES (Mark as binary)
# ============================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.eps binary
*.pdf binary

# ============================================
# COMPRESSED FILES
# ============================================
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.rar binary

# ============================================
# LINE ENDINGS
# ============================================
# Force Unix line endings for scripts (important for cross-platform)
scripts/*.py text eol=lf
scripts/*.sh text eol=lf

# Keep Windows line endings for batch files
*.bat text eol=crlf